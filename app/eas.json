{
  "cli": {
    "version": ">= 7.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://dsce-canteen-backend.onrender.com",
        "EXPO_PUBLIC_PAYMENT_API_URL": "https://dsce-canteen-backend.onrender.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
