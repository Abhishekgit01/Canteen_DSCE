# App
PORT=4000
NODE_ENV=production
FRONTEND_URL=https://dsce-canteen-admin.vercel.app
ALLOWED_ORIGINS=https://dsce-canteen-admin.vercel.app,exp://
PAYMENT_MODE=upi_link
# Options: mock | upi_link | razorpay
CANTEEN_UPI_ID=canteen@upi
CANTEEN_NAME=DSCE+Canteen

# Email (Gmail SMTP)
AUTH_VERIFICATION_MODE=auto
# Options: auto | email | none
# auto: try email OTP, but auto-verify if email delivery is unavailable
# email: require OTP and fail signup if email delivery fails
# none: disable OTP completely and verify users immediately
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@dsce.edu.in
EMAIL_PASS=your-gmail-app-password

# Razorpay (get from razorpay.com/dashboard — use test keys first)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
