# Database
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/dsce-canteen

# App
PORT=4000
NODE_ENV=production
ALLOWED_ORIGINS=https://dsce-canteen-admin.vercel.app,exp://

# Auth
JWT_SECRET=<generate a 64-char random hex string>
QR_SECRET=<generate another different 64-char random hex string>

# Email service (get free key from resend.com)
RESEND_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=

# Auth verification mode: auto | email | none
AUTH_VERIFICATION_MODE=auto

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=<your razorpay key secret>
RAZORPAY_WEBHOOK_SECRET=<set this in Razorpay dashboard under webhooks>

# Payment mode: razorpay | mock | upi_link
PAYMENT_MODE=razorpay

# UPI link mode (only used if PAYMENT_MODE=upi_link)
CANTEEN_UPI_ID=canteen@upi
CANTEEN_NAME=DSCE+Canteen

# Internal secret for server-to-server Socket.io emit
INTERNAL_SECRET=<random string>

# Cloudflare Worker (payment critical routes - zero cold start)
CF_WORKER_URL=https://your-worker.your-subdomain.workers.dev
RENDER_INTERNAL_URL=https://your-app.onrender.com
MONGO_DATA_API_KEY=<Atlas Data API key>
MONGO_DATA_API_URL=https://data.mongodb-api.com/app/<app-id>/endpoint/data/v1
